---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p>&copy; {today.getFullYear()} AI Life OS</p>
		<p class="footer-sub">
			Built with an autonomous content pipeline.
			<a href="https://github.com/heathensxyz/ai-life-os" target="_blank">Source on GitHub</a>
		</p>
	</div>
</footer>

<style>
	footer {
		text-align: center;
		padding: 40px 24px;
		background: var(--white);
		border-top: 1px solid var(--border);
		font-size: 0.82rem;
		color: var(--text-muted);
	}
	.footer-inner {
		max-width: 900px;
		margin: 0 auto;
	}
	.footer-sub {
		margin-top: 4px;
	}
	.footer-sub a {
		color: var(--primary-dark);
		text-decoration: none;
	}
	.footer-sub a:hover { color: var(--primary); }
</style>
