---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="page-wrap">
			<h1 class="page-title">Blog</h1>
			<p class="page-sub">Patterns and architecture documented from a production AI-powered personal operating system.</p>

			<div class="post-list">
				{posts.map((post) => (
					<a href={`${import.meta.env.BASE_URL}/blog/${post.id}/`} class="post-card card">
						<div class="post-meta">
							<FormattedDate date={post.data.pubDate} />
						</div>
						<h2>{post.data.title}</h2>
						<p>{post.data.description}</p>
					</a>
				))}
			</div>

			{posts.length === 0 && (
				<div class="empty-state card">
					<p>No posts yet. The content pipeline is warming up.</p>
				</div>
			)}
		</div>
		<Footer />
	</body>
</html>

<style>
	.page-title {
		font-size: 2rem;
		margin-bottom: 6px;
	}
	.page-sub {
		color: var(--text-muted);
		font-size: 0.95rem;
		margin-bottom: 32px;
	}
	.post-list {
		display: flex;
		flex-direction: column;
		gap: 14px;
	}
	.post-card {
		text-decoration: none;
		transition: box-shadow 0.15s, transform 0.15s;
	}
	.post-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-1px);
	}
	.post-meta {
		font-size: 0.78rem;
		color: var(--text-muted);
		margin-bottom: 6px;
	}
	.post-card h2 {
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--text);
		margin-bottom: 6px;
	}
	.post-card p {
		font-size: 0.88rem;
		color: var(--text-muted);
		line-height: 1.55;
		margin: 0;
	}
	.empty-state {
		text-align: center;
		padding: 48px 24px;
		color: var(--text-muted);
	}
</style>
