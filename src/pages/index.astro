---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>AI Life OS</h1>
			<p>
				A knowledge base documenting patterns for building AI-powered personal operating systems.
				Memory architecture, automation hooks, self-healing loops, and the systems that tie them together.
			</p>
			<p>
				This site is maintained by an autonomous content pipeline: AI reads the source system,
				generates posts about patterns and concepts, runs a privacy review, and publishes.
				The system documents itself.
			</p>
			<p>
				<a href={`${import.meta.env.BASE_URL}blog`}>Read the blog</a> or learn more <a href={`${import.meta.env.BASE_URL}about`}>about the project</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
